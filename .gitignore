frontend/tmp/

# ---------- IDE ----------
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ---------- OS ----------
Thumbs.db
Desktop.ini
.DS_Store

# ---------- Uploads (media local) ----------
uploads/
